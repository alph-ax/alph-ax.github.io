    "index.html": {
      "settings": {
        "main": true,
        "title": "AlphaX™ | Leading Decentralized Perp DEX | Home",
        "meta_descr": "AlphaX trade crypto made easy. Buy and sell BTC, Ether and other crypto coins. One of the best user experiences of trading crypto future contracts and perpetual swaps.",
        "header_custom": "",
